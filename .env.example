# ─── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL (recommended): project settings > database > connection string
# Railway PostgreSQL: use the connection string from Railway dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/futureyou"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI (server-side only — never expose to browser) ─────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Optional: Node environment ───────────────────────────────────────────────
NODE_ENV="development"
