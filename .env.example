# ─── Database ────────────────────────────────────────────────────────────────
# Supabase PostgreSQL (recommended): project settings > database > connection string
# Railway PostgreSQL: use the connection string from Railway dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/futureyou"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Insights (server-side only — never expose to browser) ───────────────────
INSIGHTS_API_KEY="sk-..."
INSIGHTS_API_ENDPOINT="https://your-inference-endpoint/v1/messages"
INSIGHTS_MODEL="your-model-id"
INSIGHTS_VERSION_HEADER="your-version-header-name"
INSIGHTS_API_VERSION="your-version-value"

# ─── Optional: Node environment ───────────────────────────────────────────────
NODE_ENV="development"
